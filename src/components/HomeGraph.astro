<div id="graph-container" style="position:relative;" data-astro-reload>
  <div id="graph-controls" style="position:absolute;top:10px;right:10px;z-index:2;display:flex;gap:8px;">
    <button id="fullscreen-btn" title="Pantalla completa" style="padding:4px 8px;">⛶</button>
    <button id="reset-zoom-btn" title="Restablecer zoom" style="padding:4px 8px;">🔍</button>
  </div>
  <svg id="connection-graph" style="display:block;"></svg>
</div>

<!-- Carga robusta del inicializador desde public/scripts (no desde src/) -->
<!-- Asegúrate de que d3.js está incluido globalmente en tu layout/base -->
<script type="module" src="/SQLPv3/scripts/home-graph-client.js"></script>

<style>
  /* Tus estilos actuales */
  #graph-container {
    width: 100%;
    /* ... */
  }
