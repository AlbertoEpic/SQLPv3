---
import { withBase } from '@/utils/base-url';

const graphDataUrl = withBase('/graph/graph-data.json');
const postsBaseUrl = withBase('/posts');
---

<div id="home-graph-root" data-graph-url={graphDataUrl} data-posts-base={postsBaseUrl} class="relative flex flex-col md:flex-row gap-6">
  <button id="graph-fullscreen-toggle" type="button" aria-label="Abrir gráfico a pantalla completa" class="absolute top-2 right-14 z-20 p-2 rounded-full bg-primary-200 dark:bg-primary-800 hover:bg-primary-300 dark:hover:bg-primary-700 border border-primary-300 dark:border-primary-600 shadow-md">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-700 dark:text-primary-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 3H5a2 2 0 00-2 2v3m16-5h-3m3 0v3M3 16v3a2 2 0 002 2h3m11-5v3a2 2 0 01-2 2h-3" />
    </svg>
  </button>

  <!-- Icono de ajustes -->
  <button id="graph-settings-toggle" type="button" aria-label="Mostrar configuración del gráfico" class="absolute top-2 right-2 z-20 p-2 rounded-full bg-primary-200 dark:bg-primary-800 hover:bg-primary-300 dark:hover:bg-primary-700 border border-primary-300 dark:border-primary-600 shadow-md">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-700 dark:text-primary-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" />
    </svg>
  </button>

  <!-- Panel de configuración oculto por defecto -->
  <aside id="graph-settings-panel" class="fixed top-0 right-0 w-full max-w-xs shrink-0 bg-primary-100/90 dark:bg-primary-900/95 rounded-xl border border-primary-200 dark:border-primary-700 p-4 mb-4 shadow-xl transition-opacity duration-200 ease-in-out opacity-0 pointer-events-none" style="z-index:30;">
    <h4 class="font-semibold mb-3 text-primary-800 dark:text-primary-100 text-sm">Configuración del gráfico</h4>
    <div class="flex flex-col gap-4">
      <label class="flex flex-col gap-1 text-xs">
        Fuerza de repulsión
        <input id="graph-charge" type="range" min="-600" max="-50" step="10" value="-220" />
        <span id="graph-charge-value" class="text-right text-[11px] text-primary-500">-220</span>
      </label>
      <label class="flex flex-col gap-1 text-xs">
        Distancia de enlaces
        <input id="graph-link-distance" type="range" min="40" max="300" step="5" value="95" />
        <span id="graph-link-distance-value" class="text-right text-[11px] text-primary-500">95</span>
      </label>
      <label class="flex flex-col gap-1 text-xs">
        Tamaño base de nodos
        <input id="graph-node-size" type="range" min="3" max="24" step="1" value="8" />
        <span id="graph-node-size-value" class="text-right text-[11px] text-primary-500">8</span>
      </label>
      <label class="flex items-center gap-2 text-xs">
        <input id="graph-show-labels" type="checkbox" checked />
        Mostrar etiquetas
      </label>
      <button id="graph-reset-btn" type="button" class="mt-2 rounded border border-primary-300 dark:border-primary-600 px-2 py-1 text-xs text-primary-700 dark:text-primary-200 hover:bg-primary-200 dark:hover:bg-primary-800">Resetear vista</button>
    </div>
  </aside>

  <div class="flex-1 min-w-0">
    <!-- Controles de búsqueda, exclusión y limpiar eliminados según solicitud del usuario -->

    <!-- Texto de sintaxis soportada eliminado según solicitud del usuario -->

    <div
      id="home-graph-container"
      class="w-full h-full min-h-[500px] bg-primary-50 dark:bg-primary-800 rounded-lg border border-primary-200 dark:border-primary-700 overflow-hidden relative"
      style="touch-action: none;"
    >
      <!-- Graph will be rendered here -->
    </div>
  </div>
</div>

<script>
  function setupGraphFullscreenToggle() {
    const fullscreenBtn = document.getElementById('graph-fullscreen-toggle') as HTMLButtonElement | null;
    const graphContainer = document.getElementById('home-graph-container') as (HTMLElement & { webkitRequestFullscreen?: () => Promise<void> }) | null;
    const fullDoc = document as Document & {
      webkitFullscreenElement?: Element;
      webkitExitFullscreen?: () => Promise<void>;
    };

    if (!fullscreenBtn || !graphContainer) return;

    const refreshAfterFullscreenChange = () => {
      window.setTimeout(() => {
        reRenderWithCurrentFilters();
      }, 60);
    };

    fullscreenBtn.onclick = async () => {
      const isFullscreen = fullDoc.fullscreenElement === graphContainer || fullDoc.webkitFullscreenElement === graphContainer;
      try {
        if (isFullscreen) {
          if (fullDoc.exitFullscreen) await fullDoc.exitFullscreen();
          else if (fullDoc.webkitExitFullscreen) await fullDoc.webkitExitFullscreen();
        } else {
          if (graphContainer.requestFullscreen) await graphContainer.requestFullscreen();
          else if (graphContainer.webkitRequestFullscreen) await graphContainer.webkitRequestFullscreen();
        }
      } catch {
        // No-op: fullscreen puede fallar por restricciones del navegador.
      }
    };

    document.addEventListener('fullscreenchange', refreshAfterFullscreenChange);
    document.addEventListener('webkitfullscreenchange', refreshAfterFullscreenChange as EventListener);
  }

  // Mostrar/ocultar panel de configuración
  function setupGraphSettingsPanel() {
    const toggleBtn = document.getElementById('graph-settings-toggle');
    const panel = document.getElementById('graph-settings-panel');
    if (!toggleBtn || !panel) return;
    let open = false;
    function showPanel() {
      if (!panel) return;
      panel.classList.remove('opacity-0', 'pointer-events-none');
      panel.classList.add('opacity-100');
      open = true;
    }
    function hidePanel() {
      if (!panel) return;
      panel.classList.remove('opacity-100');
      panel.classList.add('opacity-0', 'pointer-events-none');
      open = false;
    }
    toggleBtn.onclick = () => {
      if (open) {
        hidePanel();
      } else {
        showPanel();
      }
    };
    // Cerrar al hacer click fuera
    document.addEventListener('click', (e) => {
      if (!open || !panel || !toggleBtn) return;
      const target = e.target;
      if (target && target instanceof Node) {
        if (!panel.contains(target) && !toggleBtn.contains(target)) {
          hidePanel();
        }
      }
    });
  }
  import * as d3 from 'd3';
  import { getGraphThemeColors } from '@/utils/graph-theme-colors';

  interface RawGraphNode {
    id: string;
    title?: string;
    name?: string;
    slug?: string;
    type?: string;
    connections?: number;
    tags?: string[];
    categories?: string[];
    folder?: string;
    sourcePath?: string;
  }

  interface RawGraphConnection {
    source: string;
    target: string;
  }

  interface GraphNode {
    id: string;
    name: string;
    slug?: string;
    radius: number;
    group?: string;
    tags: string[];
    categories: string[];
    categoryKey?: string;
    folder: string;
    sourcePath: string;
    x?: number;
    y?: number;
    fx?: number | null;
    fy?: number | null;
  }

  interface GraphLink {
    source: string | GraphNode;
    target: string | GraphNode;
    value: number;
  }

  interface GraphData {
    nodes: GraphNode[];
    links: GraphLink[];
  }

  type TokenFilters = {
    includeText: string[];
    excludeText: string[];
    includeTags: string[];
    excludeTags: string[];
    includeFolders: string[];
    excludeFolders: string[];
  };

  let homeGraphInitialized = false;
  let svg: d3.Selection<SVGSVGElement, unknown, null, undefined> | null = null;
  let simulation: d3.Simulation<GraphNode, undefined> | null = null;
  let cleanup: (() => void) | null = null;
  let fullGraphData: GraphData | null = null;
  let currentSearchValue = '';
  let currentExcludeFolders = '';
  let filterDebounce: number | null = null;
  let graphConfig = { charge: -220, linkDistance: 95, nodeSize: 8, showLabels: true };

  function normalizeToken(input: string): string {
    return input.trim().toLowerCase();
  }

  function toTagToken(raw: string): string {
    const n = normalizeToken(raw);
    return n.startsWith('#') ? n.slice(1) : n;
  }

  function parseSearchQuery(query: string): TokenFilters {
    const parsed: TokenFilters = {
      includeText: [],
      excludeText: [],
      includeTags: [],
      excludeTags: [],
      includeFolders: [],
      excludeFolders: [],
    };

    const tokens = query.split(/\s+/).map((t) => t.trim()).filter(Boolean);
    for (const token of tokens) {
      const negative = token.startsWith('-');
      const raw = negative ? token.slice(1) : token;
      const normalized = normalizeToken(raw);

      if (normalized.startsWith('tag:')) {
        const value = toTagToken(normalized.slice(4));
        if (!value) continue;
        if (negative) parsed.excludeTags.push(value);
        else parsed.includeTags.push(value);
        continue;
      }

      if (normalized.startsWith('folder:')) {
        const value = normalizeToken(normalized.slice(7));
        if (!value) continue;
        if (negative) parsed.excludeFolders.push(value);
        else parsed.includeFolders.push(value);
        continue;
      }

      if (!normalized) continue;
      if (negative) parsed.excludeText.push(normalized);
      else parsed.includeText.push(normalized);
    }

    return parsed;
  }

  function parseExcludedFolders(input: string): string[] {
    return input
      .split(',')
      .map((item) => normalizeToken(item))
      .filter(Boolean);
  }

  function matchesText(node: GraphNode, textToken: string): boolean {
    const haystack = [node.name, node.slug || '', node.id, node.sourcePath, node.folder, ...(node.tags || []), ...(node.categories || [])]
      .join(' ')
      .toLowerCase();
    return haystack.includes(textToken);
  }

  function applyFilters(graphData: GraphData, query: string, excludedFoldersInput: string): GraphData {
    const parsed = parseSearchQuery(query);
    const explicitExcludedFolders = parseExcludedFolders(excludedFoldersInput);
    const excludedFolders = new Set([...parsed.excludeFolders, ...explicitExcludedFolders]);
    const includedFolders = new Set(parsed.includeFolders);
    const includeTags = new Set(parsed.includeTags);
    const excludeTags = new Set(parsed.excludeTags);

    const filteredNodes = graphData.nodes.filter((node) => {
      const nodeTags = (node.tags || []).map(toTagToken);
      const nodeFolder = normalizeToken(node.folder || '');

      if (includedFolders.size > 0 && !includedFolders.has(nodeFolder)) return false;
      if (excludedFolders.has(nodeFolder)) return false;

      if (includeTags.size > 0) {
        const hasAll = Array.from(includeTags).every((tag) => nodeTags.includes(tag));
        if (!hasAll) return false;
      }

      if (excludeTags.size > 0) {
        const hasExcluded = Array.from(excludeTags).some((tag) => nodeTags.includes(tag));
        if (hasExcluded) return false;
      }

      if (parsed.includeText.length > 0) {
        const allText = parsed.includeText.every((t) => matchesText(node, t));
        if (!allText) return false;
      }

      if (parsed.excludeText.length > 0) {
        const anyText = parsed.excludeText.some((t) => matchesText(node, t));
        if (anyText) return false;
      }

      return true;
    });

    const allowedIds = new Set(filteredNodes.map((n) => n.id));
    const filteredLinks = graphData.links.filter((link) => {
      const sourceId = typeof link.source === 'object' ? link.source.id : link.source;
      const targetId = typeof link.target === 'object' ? link.target.id : link.target;
      return allowedIds.has(sourceId) && allowedIds.has(targetId);
    });

    return { nodes: filteredNodes, links: filteredLinks };
  }

  function renderEmptyState(container: HTMLElement, message: string): void {
    if (cleanup) {
      cleanup();
      cleanup = null;
    }

    container.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;height:100%;text-align:center;" class="text-primary-500 dark:text-primary-400"><div><svg style="width:2.5rem;height:2.5rem;margin:0 auto 0.75rem;opacity:0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H5a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg><p class="text-sm">${message}</p></div></div>`;
  }

  function renderLoading(container: HTMLElement): void {
    container.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;height:100%;text-align:center;" class="text-primary-500 dark:text-primary-400"><div><div class="animate-spin" style="width:2rem;height:2rem;margin:0 auto 1rem;opacity:0.5;"><svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg></div><p style="font-size:0.875rem;">Loading graph...</p></div></div>`;
  }

  function getThemeColors() {
    return getGraphThemeColors();
  }

  function buildDisplayGraphData(data: GraphData): GraphData {
    const nodes = data.nodes.map((node) => ({ ...node }));
    const links = data.links.map((link) => ({ ...link }));

    const categoryNodeMap = new Map<string, GraphNode>();
    const categoryLinkSet = new Set<string>();

    for (const postNode of data.nodes) {
      if ((postNode.group || 'post') !== 'post') continue;
      const uniqueCategories = Array.from(new Set((postNode.categories || []).map((category) => normalizeToken(String(category))).filter(Boolean)));
      for (const categoryKey of uniqueCategories) {
        const categoryId = `category:${categoryKey}`;
        if (!categoryNodeMap.has(categoryId)) {
          const label = (postNode.categories || []).find((cat) => normalizeToken(String(cat)) === categoryKey) || categoryKey;
          categoryNodeMap.set(categoryId, {
            id: categoryId,
            name: `Categoria: ${label}`,
            radius: Math.max(14, Math.floor(graphConfig.nodeSize * 1.8)),
            group: 'category',
            tags: [],
            categories: [label],
            categoryKey,
            folder: '',
            sourcePath: '',
          });
        }

        const linkKey = `${categoryId}=>${postNode.id}`;
        if (!categoryLinkSet.has(linkKey)) {
          categoryLinkSet.add(linkKey);
          links.push({
            source: categoryId,
            target: postNode.id,
            value: 1,
          });
        }
      }
    }

    nodes.push(...Array.from(categoryNodeMap.values()));

    if (!graphConfig.showLabels) {
      return {
        nodes,
        links,
      };
    }

    const tagNodeMap = new Map<string, GraphNode>();
    const tagLinkSet = new Set<string>();

    for (const postNode of data.nodes) {
      if ((postNode.group || 'post') !== 'post') continue;
      const uniqueTags = Array.from(new Set((postNode.tags || []).map((tag) => toTagToken(String(tag))).filter(Boolean)));
      for (const tagToken of uniqueTags) {
        const tagId = `tag:${tagToken}`;
        if (!tagNodeMap.has(tagId)) {
          tagNodeMap.set(tagId, {
            id: tagId,
            name: `#${tagToken}`,
            radius: Math.max(3, Math.floor(graphConfig.nodeSize * 0.8)),
            group: 'tag',
            tags: [],
            categories: [],
            folder: '',
            sourcePath: '',
          });
        }

        const linkKey = `${postNode.id}=>${tagId}`;
        if (!tagLinkSet.has(linkKey)) {
          tagLinkSet.add(linkKey);
          links.push({
            source: postNode.id,
            target: tagId,
            value: 0.6,
          });
        }
      }
    }

    nodes.push(...Array.from(tagNodeMap.values()));
    return { nodes, links };
  }

  function renderHomeGraph(container: HTMLElement, data: GraphData): void {
    if (cleanup) {
      cleanup();
      cleanup = null;
    }

    container.innerHTML = '';

    if (data.nodes.length === 0) {
      renderEmptyState(container, 'Sin resultados para los filtros actuales.');
      return;
    }

    const colors = getThemeColors();
    const width = container.offsetWidth;
    const height = container.offsetHeight;

    const displayData = buildDisplayGraphData(data);
    const links = displayData.links.map((d) => ({ ...d }));
    const nodes = displayData.nodes.map((d) => ({ ...d }));

    const isCategoryNode = (node: GraphNode): boolean => {
      return node.group === 'category' || node.id.startsWith('category:');
    };

    const isTagNode = (node: GraphNode): boolean => {
      return node.group === 'tag' || node.id.startsWith('tag:');
    };

    const getCategoryColor = (node: GraphNode): string => {
      const key = node.categoryKey || node.id;
      const hash = Array.from(key).reduce((acc, ch) => acc + ch.charCodeAt(0), 0);
      const mix = (hash % 7) / 10 + 0.15;
      return d3.interpolateRgb(colors.highlight, colors.postFill)(mix);
    };

    const getNodeBaseColor = (node: GraphNode): string => {
      if (isCategoryNode(node)) return getCategoryColor(node);
      return isTagNode(node) ? colors.highlight : colors.postFill;
    };

    const getNodeStrokeColor = (node: GraphNode): string => {
      if (isCategoryNode(node)) return colors.highlight;
      return isTagNode(node) ? colors.tagStroke : colors.postStroke;
    };

    const isTagLink = (edge: GraphLink): boolean => {
      const src = typeof edge.source === 'object' ? edge.source.id : edge.source;
      const tgt = typeof edge.target === 'object' ? edge.target.id : edge.target;
      return src.startsWith('tag:') || tgt.startsWith('tag:');
    };

    const isCategoryLink = (edge: GraphLink): boolean => {
      const src = typeof edge.source === 'object' ? edge.source.id : edge.source;
      const tgt = typeof edge.target === 'object' ? edge.target.id : edge.target;
      return src.startsWith('category:') || tgt.startsWith('category:');
    };

    simulation = d3
      .forceSimulation<GraphNode>(nodes)
      .force('link', d3.forceLink<GraphNode, GraphLink>(links).id((d) => d.id).distance((edge) => (isCategoryLink(edge) ? graphConfig.linkDistance + 28 : graphConfig.linkDistance)))
      .force('charge', d3.forceManyBody().strength(graphConfig.charge))
      .force('center', d3.forceCenter(width / 2, height / 2))
      .force('collision', d3.forceCollide<GraphNode>().radius((node) => {
        if (isCategoryNode(node)) return 25;
        if (isTagNode(node)) return 12;
        return 8;
      }));

    const localSvg = d3
      .select(container)
      .append('svg')
      .attr('width', width)
      .attr('height', height)
      .attr('viewBox', [0, 0, width, height] as any)
      .style('cursor', 'grab');

    svg = localSvg;

    const containerGroup = localSvg.append('g');

    const zoom = d3.zoom<SVGSVGElement, unknown>().scaleExtent([0.4, 4]).on('zoom', (event) => {
      containerGroup.attr('transform', event.transform);
    });

    localSvg.call(zoom as any);

    const link = containerGroup
      .append('g')
      .attr('stroke-opacity', 0.2)
      .selectAll('line')
      .data(links)
      .join('line')
      .attr('stroke', (edge) => {
        if (isCategoryLink(edge)) return colors.highlight;
        return isTagLink(edge) ? colors.highlight : colors.linkStroke;
      })
      .attr('stroke-opacity', (edge) => {
        if (isCategoryLink(edge)) return 0.22;
        return isTagLink(edge) ? 0.58 : 0.14;
      })
      .attr('stroke-width', (edge) => (isCategoryLink(edge) ? 1.2 : isTagLink(edge) ? 1.7 : 1));

    const nodeGroup = containerGroup
      .append('g')
      .selectAll('g')
      .data(nodes)
      .join('g')
      .call(
        d3
          .drag<SVGGElement, GraphNode>()
          .on('start', function (event) {
            if (!event.active) simulation?.alphaTarget(0.1).restart();
            event.subject.fx = event.subject.x;
            event.subject.fy = event.subject.y;
          })
          .on('drag', function (event, d) {
            d.fx = event.x;
            d.fy = event.y;
          })
          .on('end', function (event) {
            if (!event.active) simulation?.alphaTarget(0);
            event.subject.fx = null;
            event.subject.fy = null;
          }) as any,
      );

    const neighbors = new Map<string, Set<string>>();
    for (const edge of links) {
      const src = typeof edge.source === 'object' ? edge.source.id : edge.source;
      const tgt = typeof edge.target === 'object' ? edge.target.id : edge.target;
      if (!neighbors.has(src)) neighbors.set(src, new Set());
      if (!neighbors.has(tgt)) neighbors.set(tgt, new Set());
      neighbors.get(src)?.add(tgt);
      neighbors.get(tgt)?.add(src);
    }

    nodeGroup
      .on('mouseover', function (_event, nodeDatum) {
        const connected = neighbors.get(nodeDatum.id) ?? new Set<string>();
        connected.add(nodeDatum.id);

        link
          .transition()
          .duration(120)
          .attr('stroke', (edge) => {
            const src = typeof edge.source === 'object' ? edge.source.id : edge.source;
            const tgt = typeof edge.target === 'object' ? edge.target.id : edge.target;
            return src === nodeDatum.id || tgt === nodeDatum.id ? colors.tagFill : colors.linkStroke;
          })
          .attr('stroke-opacity', (edge) => {
            const src = typeof edge.source === 'object' ? edge.source.id : edge.source;
            const tgt = typeof edge.target === 'object' ? edge.target.id : edge.target;
            return src === nodeDatum.id || tgt === nodeDatum.id ? 0.85 : 0.08;
          });

        nodeGroup
          .selectAll<SVGCircleElement, GraphNode>('circle')
          .attr('fill-opacity', (n) => (connected.has(n.id) ? 1 : 0.28))
          .attr('fill', (n) => (n.id === nodeDatum.id ? colors.tagFill : getNodeBaseColor(n)));

        nodeGroup
          .selectAll<SVGTextElement, GraphNode>('text')
          .style('opacity', (n) => (connected.has(n.id) ? 1 : 0.15));
      })
      .on('mouseout', function () {
        link
          .transition()
          .duration(120)
          .attr('stroke', (edge) => (isTagLink(edge) ? colors.highlight : colors.linkStroke))
          .attr('stroke-opacity', (edge) => (isTagLink(edge) ? 0.72 : 0.16));
        nodeGroup
          .selectAll<SVGCircleElement, GraphNode>('circle')
          .attr('fill', (n) => getNodeBaseColor(n))
          .attr('fill-opacity', (n) => (isTagNode(n) ? 1 : 0.72));
        nodeGroup.selectAll<SVGTextElement, GraphNode>('text').style('opacity', 0.62);
      });

    const node = nodeGroup
      .append('circle')
      .attr('r', (d) => {
        const baseRadius = graphConfig.nodeSize + Math.max(0, d.radius - 8);
        if (isCategoryNode(d)) return Math.max(baseRadius + 8, 14);
        return isTagNode(d) ? baseRadius + 2 : baseRadius;
      })
      .attr('cursor', 'pointer')
      .attr('fill-opacity', (d) => (isCategoryNode(d) || isTagNode(d) ? 1 : 0.72))
      .attr('fill', (d) => getNodeBaseColor(d))
      .attr('stroke', (d) => getNodeStrokeColor(d))
      .attr('stroke-width', (d) => (isCategoryNode(d) ? 3 : isTagNode(d) ? 2.8 : 1.1))
      .style('filter', (d) => (isCategoryNode(d) || isTagNode(d) ? `drop-shadow(0 0 7px ${colors.highlight})` : 'none'))
      .attr('data-id', (d) => d.id);

    node.append('title').text((d) => {
      const tagsText = d.tags.length > 0 ? `\nTags: ${d.tags.join(', ')}` : '';
      const folderText = d.folder ? `\nFolder: ${d.folder}` : '';
      return `${d.name}${tagsText}${folderText}`;
    });

    node.on('click', function (_event, d) {
      if (!d.slug) return;
      const root = document.getElementById('home-graph-root');
      const postsBase = root?.dataset.postsBase ?? '/posts';
      const url = `${postsBase.replace(/\/$/, '')}/${d.slug}`;
      const swup = (window as any).swup;
      if (swup?.navigate) swup.navigate(url);
      else window.location.href = url;
    });

    nodeGroup
      .append('text')
      .text((d) => d.name ?? d.id)
      .attr('text-anchor', 'middle')
      .attr('dy', (d) => {
        const baseRadius = graphConfig.nodeSize + Math.max(0, d.radius - 8);
        if (isCategoryNode(d)) return Math.max(baseRadius + 8, 14) + 11;
        return (isTagNode(d) ? baseRadius + 2 : baseRadius) + 9;
      })
      .style('font-size', (d) => (isCategoryNode(d) ? '10px' : isTagNode(d) ? '9px' : '8px'))
      .style('fill', (d) => (isCategoryNode(d) ? colors.tagText : isTagNode(d) ? colors.tagText : colors.postText))
      .style('font-weight', (d) => (isCategoryNode(d) || isTagNode(d) ? '600' : '400'))
      .style('pointer-events', 'none')
      .style('opacity', (d) => {
        if (!graphConfig.showLabels) return 0;
        if (isCategoryNode(d)) return 0.98;
        return isTagNode(d) ? 0.95 : 0.5;
      });

    const fitGraphToViewport = (extraPadding = 0) => {
      if (nodes.length === 0) return;
      const padding = 60 + extraPadding;
      let minX = Number.POSITIVE_INFINITY;
      let maxX = Number.NEGATIVE_INFINITY;
      let minY = Number.POSITIVE_INFINITY;
      let maxY = Number.NEGATIVE_INFINITY;
      for (const n of nodes) {
        const baseRadius = graphConfig.nodeSize + Math.max(0, n.radius - 8);
        if (isCategoryNode(n)) {
          const categoryRadius = Math.max(baseRadius + 8, 14);
          const x = n.x ?? width / 2;
          const y = n.y ?? height / 2;
          minX = Math.min(minX, x - categoryRadius);
          maxX = Math.max(maxX, x + categoryRadius);
          minY = Math.min(minY, y - categoryRadius);
          maxY = Math.max(maxY, y + categoryRadius);
          continue;
        }
        const radius = isTagNode(n) ? baseRadius + 2 : baseRadius;
        const x = n.x ?? width / 2;
        const y = n.y ?? height / 2;
        minX = Math.min(minX, x - radius);
        maxX = Math.max(maxX, x + radius);
        minY = Math.min(minY, y - radius);
        maxY = Math.max(maxY, y + radius);
      }
      const graphWidth = Math.max(1, maxX - minX);
      const graphHeight = Math.max(1, maxY - minY);
      const scale = Math.max(
        0.08,
        Math.min(
          2,
          Math.min((width - padding * 2) / graphWidth, (height - padding * 2) / graphHeight),
        ),
      );
      const centerX = (minX + maxX) / 2;
      const centerY = (minY + maxY) / 2;
      const transform = d3.zoomIdentity
        .translate(width / 2 - centerX * scale, height / 2 - centerY * scale)
        .scale(scale);
      localSvg.call(zoom.transform as any, transform as any);
    };

    // Más ticks para estabilizar el grafo antes del fit
    for (let i = 0; i < 600; ++i) simulation.tick();

    link
      .attr('x1', (d: any) => d.source.x)
      .attr('y1', (d: any) => d.source.y)
      .attr('x2', (d: any) => d.target.x)
      .attr('y2', (d: any) => d.target.y);
    nodeGroup.attr('transform', (d: any) => `translate(${d.x},${d.y})`);
    fitGraphToViewport();
    // Ajuste extra tras un retardo para asegurar que todos los nodos estén en vista
    setTimeout(() => {
      fitGraphToViewport();
    }, 200);

    simulation.on('tick', () => {
      link
        .attr('x1', (d: any) => d.source.x)
        .attr('y1', (d: any) => d.source.y)
        .attr('x2', (d: any) => d.target.x)
        .attr('y2', (d: any) => d.target.y);
      nodeGroup.attr('transform', (d: any) => `translate(${d.x},${d.y})`);
    });

    simulation.alpha(1).restart();
    window.setTimeout(() => {
      fitGraphToViewport();
    }, 80);

    cleanup = () => {
      if (simulation) {
        simulation.stop();
        simulation = null;
      }
      if (svg) {
        svg.remove();
        svg = null;
      }
    };
  }

  function reRenderWithCurrentFilters(): void {
    const container = document.getElementById('home-graph-container');
    if (!container || !fullGraphData) return;
    const filtered = applyFilters(fullGraphData, currentSearchValue, currentExcludeFolders);
    renderHomeGraph(container, filtered);
  }

  function bindFilterControls(): void {
    const searchInput = document.getElementById('home-graph-search') as HTMLInputElement | null;
    const excludeInput = document.getElementById('home-graph-folder-exclude') as HTMLInputElement | null;
    const clearButton = document.getElementById('home-graph-clear') as HTMLButtonElement | null;

    if (!searchInput || !excludeInput || !clearButton) return;

    const scheduleRender = () => {
      if (filterDebounce) window.clearTimeout(filterDebounce);
      filterDebounce = window.setTimeout(() => {
        reRenderWithCurrentFilters();
      }, 120);
    };

    searchInput.oninput = () => {
      currentSearchValue = searchInput.value || '';
      scheduleRender();
    };

    excludeInput.oninput = () => {
      currentExcludeFolders = excludeInput.value || '';
      scheduleRender();
    };

    clearButton.onclick = () => {
      searchInput.value = '';
      excludeInput.value = '';
      currentSearchValue = '';
      currentExcludeFolders = '';
      reRenderWithCurrentFilters();
    };
  }

  function bindGraphConfigPanel(): void {
    const chargeInput = document.getElementById('graph-charge') as HTMLInputElement | null;
    const chargeValue = document.getElementById('graph-charge-value');
    const linkDistInput = document.getElementById('graph-link-distance') as HTMLInputElement | null;
    const linkDistValue = document.getElementById('graph-link-distance-value');
    const nodeSizeInput = document.getElementById('graph-node-size') as HTMLInputElement | null;
    const nodeSizeValue = document.getElementById('graph-node-size-value');
    const showLabelsInput = document.getElementById('graph-show-labels') as HTMLInputElement | null;
    const resetBtn = document.getElementById('graph-reset-btn') as HTMLButtonElement | null;

    if (!chargeInput || !linkDistInput || !nodeSizeInput || !showLabelsInput || !resetBtn) return;

    chargeInput.oninput = () => {
      graphConfig.charge = Number(chargeInput.value);
      if (chargeValue) chargeValue.textContent = chargeInput.value;
      reRenderWithCurrentFilters();
    };

    linkDistInput.oninput = () => {
      graphConfig.linkDistance = Number(linkDistInput.value);
      if (linkDistValue) linkDistValue.textContent = linkDistInput.value;
      reRenderWithCurrentFilters();
    };

    nodeSizeInput.oninput = () => {
      graphConfig.nodeSize = Number(nodeSizeInput.value);
      if (nodeSizeValue) nodeSizeValue.textContent = nodeSizeInput.value;
      reRenderWithCurrentFilters();
    };

    showLabelsInput.onchange = () => {
      graphConfig.showLabels = showLabelsInput.checked;
      reRenderWithCurrentFilters();
    };

    resetBtn.onclick = () => {
      graphConfig = { charge: -220, linkDistance: 95, nodeSize: 8, showLabels: true };
      chargeInput.value = '-220';
      linkDistInput.value = '95';
      nodeSizeInput.value = '8';
      showLabelsInput.checked = true;
      if (chargeValue) chargeValue.textContent = '-220';
      if (linkDistValue) linkDistValue.textContent = '95';
      if (nodeSizeValue) nodeSizeValue.textContent = '8';
      reRenderWithCurrentFilters();
    };
  }

  function mapRawDataToGraphData(data: { nodes: RawGraphNode[]; connections: RawGraphConnection[] }): GraphData {
    return {
      nodes: (data.nodes || []).map((node) => ({
        id: node.id,
        name: node.title || node.name || node.id,
        slug: node.slug,
        radius: Math.max(5, Math.min(14, (node.connections || 0) + 5)),
        group: node.type || 'post',
        tags: Array.isArray(node.tags) ? node.tags.map((tag) => String(tag)) : [],
        categories: Array.isArray(node.categories) ? node.categories.map((category) => String(category)) : [],
        folder: node.folder || '',
        sourcePath: node.sourcePath || '',
      })),
      links: (data.connections || []).map((conn) => ({
        source: conn.source,
        target: conn.target,
        value: 1,
      })),
    };
  }

  function initializeHomeGraph(): void {
    const container = document.getElementById('home-graph-container');
    const root = document.getElementById('home-graph-root');
    if (!container || !root) return;

    if (homeGraphInitialized) {
      reRenderWithCurrentFilters();
      return;
    }

    homeGraphInitialized = true;

    const dataUrl = root.getAttribute('data-graph-url');
    if (!dataUrl) {
      renderEmptyState(container, 'No se pudo determinar la URL del grafo.');
      return;
    }

    bindFilterControls();
    bindGraphConfigPanel();
    renderLoading(container);

    fetch(dataUrl)
      .then((response) => {
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        return response.json();
      })
      .then((data) => {
        fullGraphData = mapRawDataToGraphData(data);
        reRenderWithCurrentFilters();
      })
      .catch((error) => {
        renderEmptyState(container, `Graph data not available (${error.message})`);
      });
  }

  function handleThemeChange(): void {
    if (!fullGraphData) return;
    reRenderWithCurrentFilters();
  }

  if (!(window as any).initializeHomeGraph) {
    (window as any).initializeHomeGraph = () => {
      initializeHomeGraph();
      setupGraphFullscreenToggle();
      setupGraphSettingsPanel();
    };
    document.addEventListener('DOMContentLoaded', (window as any).initializeHomeGraph);
    window.addEventListener('themechange', handleThemeChange);
  }

  const swupHooks = (window as any).swup?.hooks;
  if (swupHooks?.on) {
    swupHooks.on('page:view', () => {
      homeGraphInitialized = false;
      (window as any).initializeHomeGraph?.();
    });

    swupHooks.on('visit:end', () => {
      homeGraphInitialized = false;
      (window as any).initializeHomeGraph?.();
    });
  }
</script>

