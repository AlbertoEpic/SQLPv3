<!-- --- SECCIÓN DE ESTILOS CSS --- -->
<style>
  .instagram-contenedor {
    margin: 40px auto;
    max-width: 1000px;
    padding: 0 20px;
  }
  .instagram-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 16px;
    margin-top: 20px;
  }
  .instagram-tarjeta {
    overflow: hidden;
    border-radius: 8px;
    aspect-ratio: 1 / 1;
    display: block;
  }
  .instagram-tarjeta img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .instagram-tarjeta:hover img {
    transform: scale(1.05);
  }
</style>