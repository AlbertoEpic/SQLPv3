---
// Página de filtro de posts por categoría (similar a index.astro)
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { shouldShowPost, sortPostsByDate, extractTags } from '@/utils/markdown';
import { optimizePostImagePath } from '@/utils/images';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/utils/base-url';

// Get query parameters
const url = new URL(Astro.request.url);
const selectedCategory = url.searchParams.get('category');
const selectedTag = url.searchParams.get('tag');
const searchQuery = url.searchParams.get('q');

// Get all posts
const allPosts = await getCollection('posts');

// Filter posts based on environment
const isDev = import.meta.env.DEV;
const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));

// Sort posts by date (newest first)
const sortedPosts = sortPostsByDate(visiblePosts);

const categories = Array.from(
  new Set(
    sortedPosts
      .map(post => post.data.category)
      .filter((category): category is string => typeof category === 'string' && category.trim() !== '')
  )
);

// Extract all unique tags
const allTags = extractTags(sortedPosts);

const pageTitle = selectedCategory
  ? `Posts de la categoría "${selectedCategory}"`
  : 'Filtrar posts por categoría';
const pageDescription = selectedCategory
  ? `Todos los posts de la categoría "${selectedCategory}"`
  : `Filtra los posts por categoría en ${siteConfig.title}`;

const seoData = {
  title: `${pageTitle} | ${siteConfig.title}`,
  description: pageDescription,
  canonical: Astro.url.href,
  ogType: 'website' as const
};
---

<BaseLayout seoData={seoData}>
  <section class="hero-row hero-fullbleed w-full max-w-full relative overflow-hidden border-b border-primary-200/80 dark:border-primary-700/70 mb-12"
    style={`background-image: url('${withBase('/posts/attachments/LaCristallere12-e1632560122785.webp')}'); background-size: cover; background-position: center; width: 100vw; max-width: 100vw; margin-left: -50vw; margin-right: -50vw; left: 50%; right: 50%;`}>
    <div class="hero-overlay absolute inset-0" aria-hidden="true"></div>
    <div class="relative px-4 sm:px-6 lg:px-10 py-12 md:py-16 lg:py-20">
      <div class="hero-copy max-w-2xl bg-primary-950/10 dark:bg-primary-900/10 rounded-xl p-6 shadow-lg backdrop-blur-md">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight text-white">
          {selectedCategory ? `Categoría: ${selectedCategory}` : 'Filtrar posts por categoría'}
        </h1>
        <p class="mt-4 text-base sm:text-lg text-white/90 max-w-xl">
          {selectedCategory ? `Mostrando los posts de la categoría "${selectedCategory}".` : 'Selecciona una categoría para ver los posts correspondientes.'}
        </p>
      </div>
    </div>
  </section>

  <div class="relative">
    {/* Filtros de búsqueda */}
    <div class="mb-10 p-6 bg-primary-50 dark:bg-primary-900/60 rounded-xl shadow flex flex-col md:flex-row gap-4 items-center justify-between w-full max-w-none">
      <form id="posts-filter-form" method="GET" class="w-full flex flex-col md:flex-row gap-4 items-center justify-between" data-no-swup>
        {/* Filtro por nombre */}
        <input
          type="text"
          name="q"
          placeholder="Buscar por nombre..."
          class="w-full md:w-1/3 px-3 py-2 rounded border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 text-primary-900 dark:text-primary-100 focus:outline-none focus:ring-2 focus:ring-highlight-500"
          value={searchQuery || ''}
        />
        {/* Filtro por categoría */}
        <select
          name="category"
          class="w-full md:w-1/2 lg:w-1/3 px-4 py-2 rounded-lg border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 text-primary-900 dark:text-primary-100 focus:outline-none focus:ring-2 focus:ring-highlight-500 transition-all"
        >
          <option value="" selected={!selectedCategory}>Todas las categorías</option>
          {categories.map(cat => (
            <option value={cat} selected={selectedCategory === cat}>{cat}</option>
          ))}
        </select>
        {/* Filtro por tag */}
        <select
          name="tag"
          class="w-full md:w-1/2 lg:w-1/3 px-4 py-2 rounded-lg border border-primary-300 dark:border-primary-700 bg-white dark:bg-primary-950 text-primary-900 dark:text-primary-100 focus:outline-none focus:ring-2 focus:ring-highlight-500 transition-all"
        >
          <option value="" selected={!selectedTag}>Todos los tags</option>
          {allTags.map(tag => (
            <option value={tag} selected={selectedTag === tag}>{tag}</option>
          ))}
        </select>
        <button type="submit" class="px-5 py-2 rounded-lg bg-highlight-500 text-white font-semibold shadow hover:bg-highlight-600 transition">Filtrar</button>
      </form>
    </div>

    {/* Listado de posts filtrados según los filtros activos */}
    <section class="mt-8">
      <h2 class="text-xl font-bold mb-4 text-primary-900 dark:text-primary-100">Resultados (<span id="filter-results-count">{sortedPosts.length}</span>)</h2>
      <div id="filter-empty-state" class="text-center text-red-600 font-bold my-8 hidden">No hay posts que coincidan con los filtros.</div>
      <ul class="divide-y divide-primary-200 dark:divide-primary-700">
          {sortedPosts.map(post => (
            <li>
              <a
                href={withBase(`/posts/${post.id}`)}
                class="flex items-center gap-4 py-3 hover:bg-primary-100 dark:hover:bg-primary-900/40 rounded transition"
                data-filter-item
                data-filter-title={post.data.title.toLowerCase()}
                data-filter-description={(post.data.description || '').toLowerCase()}
                data-filter-category={(post.data.category || '').toLowerCase()}
                data-filter-tags={Array.isArray(post.data.tags) ? post.data.tags.map(tag => tag.toLowerCase()).join('|') : ''}
              >
                {post.data.image && (
                  <img src={optimizePostImagePath(post.data.image, '100', post.id)} alt={post.data.imageAlt || post.data.title} class="w-[50px] h-[50px] object-cover rounded shadow-sm flex-shrink-0" loading="lazy" />
                )}
                <div>
                  <h3 class="text-base font-semibold text-primary-900 dark:text-primary-50 group-hover:text-highlight-600 mb-0">{post.data.title}</h3>
                  <span class="text-xs text-primary-500 dark:text-primary-300">{new Date(post.data.date).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                </div>
              </a>
            </li>
          ))}
      </ul>
    </section>

    </div>
</BaseLayout>

<style>
  .posts-grid {
    display: grid;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .posts-grid {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    }
  }
</style>

<Fragment slot="scripts">
  <script>
    function initializePostFilters() {
      const form = document.querySelector('#posts-filter-form');
      if (!form || form instanceof HTMLFormElement === false) return;
      if (form.dataset.filtersBound === 'true') {
        applyFiltersFromUrl();
        return;
      }

      form.dataset.filtersBound = 'true';

      const searchInput = form.querySelector('input[name="q"]');
      const categorySelect = form.querySelector('select[name="category"]');
      const tagSelect = form.querySelector('select[name="tag"]');
      const filterItems = Array.from(document.querySelectorAll('[data-filter-item]'));
      const resultsCount = document.querySelector('#filter-results-count');
      const emptyState = document.querySelector('#filter-empty-state');
      const title = document.querySelector('h1');
      const description = document.querySelector('.hero-copy p');

      const normalize = (value: string) => value.trim().toLowerCase();

      function updateHero(category: string) {
        if (!title || !description) return;

        if (category) {
          title.textContent = `Categoría: ${category}`;
          description.textContent = `Mostrando los posts de la categoría "${category}".`;
          return;
        }

        title.textContent = 'Filtrar posts por categoría';
        description.textContent = 'Selecciona una categoría para ver los posts correspondientes.';
      }

      function syncFormWithUrl() {
        const params = new URLSearchParams(window.location.search);
        if (searchInput instanceof HTMLInputElement) {
          searchInput.value = params.get('q') || '';
        }
        if (categorySelect instanceof HTMLSelectElement) {
          categorySelect.value = params.get('category') || '';
        }
        if (tagSelect instanceof HTMLSelectElement) {
          tagSelect.value = params.get('tag') || '';
        }
      }

      function updateUrl() {
        const params = new URLSearchParams();
        const query = searchInput instanceof HTMLInputElement ? searchInput.value.trim() : '';
        const category = categorySelect instanceof HTMLSelectElement ? categorySelect.value.trim() : '';
        const tag = tagSelect instanceof HTMLSelectElement ? tagSelect.value.trim() : '';

        if (query) params.set('q', query);
        if (category) params.set('category', category);
        if (tag) params.set('tag', tag);

        const nextUrl = `${window.location.pathname}${params.toString() ? `?${params.toString()}` : ''}`;
        window.history.replaceState({}, '', nextUrl);
      }

      function applyFiltersFromUrl() {
        syncFormWithUrl();

        const params = new URLSearchParams(window.location.search);
        const query = normalize(params.get('q') || '');
        const category = normalize(params.get('category') || '');
        const tag = normalize(params.get('tag') || '');

        let visibleCount = 0;
        filterItems.forEach((item) => {
          if (!(item instanceof HTMLAnchorElement)) return;

          const titleMatch = (item.dataset.filterTitle || '').includes(query);
          const descriptionMatch = (item.dataset.filterDescription || '').includes(query);
          const categoryMatch = !category || (item.dataset.filterCategory || '') === category;
          const tagMatch = !tag || (item.dataset.filterTags || '').split('|').includes(tag);
          const queryMatch = !query || titleMatch || descriptionMatch;
          const isVisible = queryMatch && categoryMatch && tagMatch;

          const parent = item.closest('li');
          if (parent instanceof HTMLElement) {
            parent.classList.toggle('hidden', !isVisible);
          }

          if (isVisible) visibleCount += 1;
        });

        if (resultsCount) {
          resultsCount.textContent = String(visibleCount);
        }

        if (emptyState instanceof HTMLElement) {
          emptyState.classList.toggle('hidden', visibleCount > 0);
        }

        updateHero(categorySelect instanceof HTMLSelectElement ? categorySelect.value.trim() : '');
      }

      form.addEventListener('submit', (event) => {
        event.preventDefault();
        updateUrl();
        applyFiltersFromUrl();
      });

      applyFiltersFromUrl();
    }

    (window as any).initializePostFilters = initializePostFilters;
    document.addEventListener('DOMContentLoaded', initializePostFilters);
    if ((window as any).swup?.hooks?.on) {
      (window as any).swup.hooks.on('page:view', initializePostFilters);
      (window as any).swup.hooks.on('visit:end', initializePostFilters);
    }
  </script>
</Fragment>
