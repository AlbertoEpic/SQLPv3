---
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { generatePageSEO } from '@/utils/seo';
import { shouldShowPost, sortPostsByDate, extractTags } from '@/utils/markdown';
import { optimizePostImagePath } from '@/utils/images';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Tags from '@/components/Tags.astro';
import Pagination from '@/components/Pagination.astro';
import Icon from '@/components/Icon.astro';
import { withBase } from '@/utils/base-url';

// Get special content for posts page
let postsPageContent: Awaited<ReturnType<typeof getCollection<'special'>>>
try {
  postsPageContent = await getCollection('special', ({ id }) => id === 'posts');
} catch (error) {
  // Fallback if special collection doesn't exist or posts.md doesn't exist
  postsPageContent = [];
}

const postsPageData = postsPageContent.length > 0 ? postsPageContent[0] : null;

// Get query parameters
const url = new URL(Astro.request.url);
const selectedTag = url.searchParams.get('tag');

// Get all posts
const allPosts = await getCollection('posts');

// Filter posts based on environment
const isDev = import.meta.env.DEV;
const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));

// Sort posts by date (newest first)
const sortedPosts = sortPostsByDate(visiblePosts);

// Extraer categorías únicas (excluyendo 'otros' y 'orientación')
const categories = Array.from(new Set(sortedPosts.map(post => post.data?.category).filter(Boolean)))
  .filter(cat => {
    const lower = cat.toLowerCase();
    return lower !== 'otros' && lower !== 'orientación';
  });

const categoryAccentClasses = ['cat-tone-1', 'cat-tone-2', 'cat-tone-3', 'cat-tone-4', 'cat-tone-5', 'cat-tone-6'];
const categoryPillToneClasses = ['pill-tone-1', 'pill-tone-2', 'pill-tone-3', 'pill-tone-4', 'pill-tone-5', 'pill-tone-6'];

// Extraer todos los tags únicos
const allTags = extractTags(sortedPosts);

// Filter by tag if specified
const filteredPosts = selectedTag
  ? sortedPosts.filter(post => post.data.tags?.includes(selectedTag))
  : sortedPosts;

// Pagination
const postsPerPage = siteConfig.postOptions.postsPerPage;
const totalPosts = filteredPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const currentPage = 1; // This is the first page
const startIndex = 0;
const endIndex = Math.min(postsPerPage, totalPosts);
const paginatedPosts = filteredPosts.slice(startIndex, endIndex);
// Generate SEO data
const pageTitle = selectedTag
  ? `Posts tagged "${selectedTag}"`
  : (postsPageData?.data.title || 'All Posts');
const pageDescription = selectedTag
  ? `All posts tagged with "${selectedTag}"`
  : (postsPageData?.data.description || `Browse all ${totalPosts} posts on ${siteConfig.title}`);

const seoData = {
  title: `${pageTitle} | ${siteConfig.title}`,
  description: pageDescription,
  canonical: Astro.url.href,
  ogType: 'website' as const
};

// Pagination info
const baseUrl = selectedTag ? withBase(`/posts/tag/${encodeURIComponent(selectedTag)}`) : withBase('/posts');
const pagination = {
  currentPage,
  totalPages,
  hasNext: currentPage < totalPages,
  hasPrev: false,
  nextUrl: totalPages > 1 ? withBase('/posts/2') : undefined,
  prevUrl: undefined
};
---

<BaseLayout seoData={seoData}>
  <Fragment slot="head">
    <!-- Preload only the first post's image to avoid unused preload warnings -->
    {paginatedPosts.length > 0 && (() => {
      const firstPost = paginatedPosts[0];
      if (!firstPost.data.image || typeof firstPost.data.image === 'string' && firstPost.data.image.startsWith('http')) return null;

      const showCoverImages = siteConfig.postOptions.showPostCardCoverImages;
      const shouldShowCoverImage = ['all', 'posts', 'featured-and-posts'].includes(showCoverImages);

      return shouldShowCoverImage ? (
        <link
          rel="preload"
          as="image"
          href={optimizePostImagePath(firstPost.data.image, undefined, firstPost.id)}
          fetchpriority="high"
        />
      ) : null;
    })()}
  </Fragment>


  <section
    class="hero-row hero-fullbleed w-full max-w-full relative overflow-hidden border-b border-primary-200/80 dark:border-primary-700/70 mb-12"
    style={`background-image: url('${withBase('/posts/attachments/LaCristallere12-e1632560122785.webp')}'); background-size: cover; background-position: center; width: 100vw; max-width: 100vw; margin-left: -50vw; margin-right: -50vw; left: 50%; right: 50%;`}
  >
    <div class="hero-overlay absolute inset-0" aria-hidden="true"></div>
    <div class="relative px-4 sm:px-6 lg:px-10 py-12 md:py-16 lg:py-20">
      <div class="hero-copy max-w-2xl bg-primary-950/10 dark:bg-primary-900/10 rounded-xl p-6 shadow-lg backdrop-blur-md">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight text-white">
          Rutipedia: SQLP blog
        </h1>
        <p class="mt-4 text-base sm:text-lg text-white/90 max-w-xl">
          El blog de SQLP, con rutas, relatos, vídeos y fotos que buscan más la estética que la utilidad...
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={withBase('/rss.xml')} class="hero-btn hero-btn-primary" data-no-swup>
            RSS Feed
            <Icon name="rss" class="w-4 h-4" />
          </a>
          <a href={withBase('/feed.xml')} class="hero-btn hero-btn-secondary" data-no-swup>
            Atom Feed
            <Icon name="atom" class="w-4 h-4" />
          </a>
        </div>
        {selectedTag && (
          <div class="mt-8">
            <a
              href={withBase('/posts')}
              class="inline-flex items-center text-sm text-primary-100/90 hover:text-white transition-colors"
            >
              <Icon name="arrow-left" class="w-4 h-4 mr-1" />
              Mostrar todas las entradas
            </a>
          </div>
        )}
      </div>
    </div>
  </section>

      <div class="relative">
        <!-- Main content -->
        <div class="max-w-none">
          {/* ISLAS POR CATEGORÍA */}
          {/* ISLAS POR CATEGORÍA */}
          {categories.length === 0 ? (
            <div class="text-center text-red-600 font-bold my-12">No se detectaron categorías en los posts.</div>
          ) : (
            <>
              {categories.map((category, categoryIndex) => {
                // Filtrar posts de la categoría que tengan imagen
                const postsByCat = sortedPosts.filter(post => post.data?.category === category && post.data?.image);
                if (postsByCat.length === 0) return null;
                const categoryAccentClass = categoryAccentClasses[categoryIndex % categoryAccentClasses.length];
                // Ordenar por fecha descendente (más reciente primero)
                const postsSorted = [...postsByCat].sort((a, b) => {
                  const dateA = new Date(a.data?.date || a.date).getTime();
                  const dateB = new Date(b.data?.date || b.date).getTime();
                  return dateB - dateA;
                });
                // Solo los 5 más recientes
                const top5 = postsSorted.slice(0, 5);
                const anchorId = `cat-${category.replace(/\s+/g, '-').toLowerCase()}`;
                return (
                  <section class={`mb-14 category-anchor category-shell ${categoryAccentClass}`} id={anchorId}>
                    <h2 class="category-title text-2xl font-bold mb-6 text-primary-900 dark:text-primary-100 border-l-4 pl-3">{category}</h2>
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                      {/* Post más reciente destacado */}
                      <div class="lg:col-span-2">
                        <a href={withBase(`/posts/${top5[0].id}`)} class="block group rounded-xl overflow-hidden shadow-lg bg-primary-50 dark:bg-primary-900/60 hover:bg-primary-100 dark:hover:bg-primary-800/80 transition h-full">
                          <img src={optimizePostImagePath(top5[0].data.image, '800', top5[0].id)} alt={top5[0].data.imageAlt || top5[0].data.title} class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                          <div class="p-6">
                            <h3 class="text-2xl font-bold text-primary-900 dark:text-primary-50 group-hover:text-highlight-600 mb-3">{top5[0].data.title}</h3>
                            <p class="text-base text-primary-700 dark:text-primary-200 line-clamp-4 mb-3">{top5[0].data.description}</p>
                            <span class="text-xs text-primary-500 dark:text-primary-300">{new Date(top5[0].data.date).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                          </div>
                        </a>
                      </div>
                      {/* Hasta 4 posts en pequeño */}
                      <div class="flex flex-col gap-6">
                        {top5.slice(1).map(post => (
                          <a href={withBase(`/posts/${post.id}`)} class="block group rounded-xl overflow-hidden shadow bg-primary-50 dark:bg-primary-900/60 hover:bg-primary-100 dark:hover:bg-primary-800/80 transition">
                            <div class="flex gap-4 items-center">
                              <img src={optimizePostImagePath(post.data.image, '200', post.id)} alt={post.data.imageAlt || post.data.title} class="w-24 h-24 object-cover rounded-l" loading="lazy" />
                              <div class="py-2 pr-2">
                                <h4 class="text-base font-semibold text-primary-900 dark:text-primary-50 group-hover:text-highlight-600 mb-1">{post.data.title}</h4>
                                <span class="text-xs text-primary-500 dark:text-primary-300">{new Date(post.data.date).toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                              </div>
                            </div>
                          </a>
                        ))}
                      </div>
                    </div>
                    {postsByCat.length > 3 && (
                      <div class="mt-6 flex justify-end">
                        <a href={withBase(`/posts/filtroposts?category=${encodeURIComponent(category)}`)} class="inline-block px-5 py-2 rounded-lg bg-highlight-500 text-white font-semibold shadow hover:bg-highlight-600 transition">Ver todos</a>
                      </div>
                    )}
                  </section>
                );
              })}
              {/* Isla de tags centrada */}
              {siteConfig.postOptions.tags && allTags.length > 0 && (
                <div
                  class="my-12 w-screen relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] px-0"
                  style={`background-image: url('${withBase('/posts/attachments/LaCristallere12-e1632560122785.webp')}'); background-size: cover; background-position: center;`}
                >
                  {/* Sin overlay, fondo 100% transparente */}
                  <div class="w-full relative z-10 py-8 flex justify-center">
                    <div class="w-[94vw] max-w-none">
                      <Tags tags={allTags} />
                    </div>
                  </div>
                </div>
              )}
            </>
          )}
        </div>

        <!-- Mobile sidebar - appears below content on mobile/tablet -->
        <div class="xl:hidden mt-12 space-y-6">
          <!-- Tags -->
          {siteConfig.postOptions.tags && allTags.length > 0 && (
            <Tags tags={allTags} />
          )}
        </div>

        <!-- Desktop sidebar - floats to the right of the content container -->
        <div class="hidden xl:block absolute top-0 left-full ml-8 w-64 h-full">
          <div class="sticky top-24 pb-6 z-10" id="tags-sidebar">
            <nav class="bg-primary-50 dark:bg-primary-900/60 rounded-xl shadow p-4">
              <h3 class="text-lg font-bold mb-3 text-primary-900 dark:text-primary-100">Categorías</h3>
              <ul class="space-y-2 relative" id="categories-menu-list">
                <div id="categories-active-pill" class="categories-active-pill" aria-hidden="true"></div>
                {categories.map((cat, catIndex) => {
                  const categoryPillToneClass = categoryPillToneClasses[catIndex % categoryPillToneClasses.length];
                  return (
                  <li key={cat} class="relative z-10">
                    <a
                      href={`#cat-${cat.replace(/\s+/g, '-').toLowerCase()}`}
                      data-pill-tone={categoryPillToneClass}
                      class="category-menu-link text-primary-700 dark:text-primary-200 hover:text-highlight-600 dark:hover:text-highlight-400 transition"
                    >
                      {cat}
                    </a>
                  </li>
                );
                })}
              </ul>
            </nav>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Enhanced posts page styles */
  .posts-grid {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .posts-grid {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    }
  }

  /* Tag highlight in header */
  .tag-highlight {
    @apply bg-gradient-to-r from-highlight-500 to-highlight-600 text-white;
  }

  .category-anchor {
    scroll-margin-top: 7rem;
  }

  .category-shell {
    position: relative;
    padding-top: 1rem;
  }

  .category-shell::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 3px;
    border-radius: 9999px;
    background: rgb(var(--category-accent-rgb) / 0.55);
  }

  .category-shell::after {
    content: '';
    position: absolute;
    inset: -0.15rem -0.35rem;
    border-radius: 1rem;
    pointer-events: none;
    background: linear-gradient(180deg, rgb(var(--category-accent-rgb) / 0.08), transparent 42%);
    z-index: -1;
  }

  .category-title {
    border-left-color: rgb(var(--category-accent-rgb) / 0.85);
  }

  .cat-tone-1 {
    --category-accent-rgb: var(--color-highlight-500);
  }

  .cat-tone-2 {
    --category-accent-rgb: var(--color-primary-500);
  }

  .cat-tone-3 {
    --category-accent-rgb: var(--color-highlight-600);
  }

  .cat-tone-4 {
    --category-accent-rgb: var(--color-primary-600);
  }

  .cat-tone-5 {
    --category-accent-rgb: var(--color-highlight-400);
  }

  .cat-tone-6 {
    --category-accent-rgb: var(--color-primary-400);
  }

  .categories-active-pill {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 2.25rem;
    border-radius: 0.75rem;
    background: linear-gradient(90deg, rgb(var(--color-highlight-500) / 0.18), rgb(var(--color-primary-400) / 0.14));
    border: 1px solid rgb(var(--color-highlight-500) / 0.28);
    box-shadow: 0 4px 16px rgb(var(--color-highlight-500) / 0.12);
    transform: translateY(0);
    opacity: 0;
    pointer-events: none;
    transition: transform 640ms cubic-bezier(0.2, 1.2, 0.3, 1), height 640ms cubic-bezier(0.2, 1.2, 0.3, 1), opacity 240ms ease, background 320ms ease, border-color 320ms ease, box-shadow 320ms ease;
  }

  :global(.dark) .categories-active-pill {
    background: linear-gradient(90deg, rgb(var(--color-highlight-400) / 0.24), rgb(var(--color-primary-300) / 0.18));
    border-color: rgb(var(--color-highlight-300) / 0.32);
    box-shadow: 0 6px 18px rgb(var(--color-highlight-400) / 0.16);
  }

  .categories-active-pill.pill-bounce {
    animation: pillBounce 620ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes pillBounce {
    0% {
      filter: saturate(1);
    }
    35% {
      filter: saturate(1.22);
    }
    100% {
      filter: saturate(1);
    }
  }

  .categories-active-pill.pill-tone-1 {
    background: linear-gradient(90deg, rgb(var(--color-highlight-500) / 0.2), rgb(var(--color-highlight-400) / 0.16));
    border-color: rgb(var(--color-highlight-500) / 0.3);
    box-shadow: 0 5px 18px rgb(var(--color-highlight-500) / 0.14);
  }

  .categories-active-pill.pill-tone-2 {
    background: linear-gradient(90deg, rgb(var(--color-primary-500) / 0.2), rgb(var(--color-primary-400) / 0.14));
    border-color: rgb(var(--color-primary-500) / 0.3);
    box-shadow: 0 5px 18px rgb(var(--color-primary-500) / 0.14);
  }

  .categories-active-pill.pill-tone-3 {
    background: linear-gradient(90deg, rgb(var(--color-highlight-600) / 0.2), rgb(var(--color-highlight-500) / 0.14));
    border-color: rgb(var(--color-highlight-600) / 0.3);
    box-shadow: 0 5px 18px rgb(var(--color-highlight-600) / 0.14);
  }

  .categories-active-pill.pill-tone-4 {
    background: linear-gradient(90deg, rgb(var(--color-primary-600) / 0.2), rgb(var(--color-primary-500) / 0.14));
    border-color: rgb(var(--color-primary-600) / 0.3);
    box-shadow: 0 5px 18px rgb(var(--color-primary-600) / 0.14);
  }

  .categories-active-pill.pill-tone-5 {
    background: linear-gradient(90deg, rgb(var(--color-highlight-400) / 0.2), rgb(var(--color-highlight-300) / 0.14));
    border-color: rgb(var(--color-highlight-400) / 0.3);
    box-shadow: 0 5px 18px rgb(var(--color-highlight-400) / 0.14);
  }

  .categories-active-pill.pill-tone-6 {
    background: linear-gradient(90deg, rgb(var(--color-primary-400) / 0.2), rgb(var(--color-primary-300) / 0.14));
    border-color: rgb(var(--color-primary-400) / 0.3);
    box-shadow: 0 5px 18px rgb(var(--color-primary-400) / 0.14);
  }

  .category-menu-link {
    display: block;
    border-radius: 0.65rem;
    padding: 0.42rem 0.55rem;
    line-height: 1.25rem;
    transition: color 180ms ease;
  }

  .category-menu-link-active {
    color: rgb(var(--color-primary-900));
    font-weight: 600;
  }

  :global(.dark) .category-menu-link-active {
    color: rgb(var(--color-primary-50));
  }
</style>

<Fragment slot="scripts">
  <script>
    // Constants for tags sidebar height calculation
    const BOTTOM_SPACING = 96; // 6rem = 96px - fixed spacing from bottom of viewport
    const MIN_SIDEBAR_HEIGHT = 200; // Minimum height for sidebar to be useful
    const CATEGORY_ANCHOR_EXTRA_OFFSET = 12; // Small breathing room under sticky header
    const CATEGORY_SCROLL_MIN_DURATION_MS = 980;
    const CATEGORY_SCROLL_MAX_DURATION_MS = 1650;
    const CATEGORY_STABILIZE_DELAY_MS = 520;

    let categoryScrollRafId: number | null = null;
    let categoryStabilizeTimeoutId: number | null = null;

    // Global function to calculate and set tags sidebar max height
    function updateTagsSidebarHeight() {
      const sidebarContent = document.querySelector('.tags-container') as HTMLElement;
      const sidebarContainer = document.querySelector('#tags-sidebar') as HTMLElement;

      if (!sidebarContent || !sidebarContainer) return;

      // Get the sidebar container's position relative to viewport
      const rect = sidebarContainer.getBoundingClientRect();
      const sidebarTop = rect.top;

      // Calculate available space: viewport height - sidebar top position - bottom spacing
      const availableHeight = window.innerHeight - sidebarTop - BOTTOM_SPACING;

      // Ensure minimum height and maximum reasonable height (don't let it be too tall)
      const maxHeight = Math.max(MIN_SIDEBAR_HEIGHT, Math.min(availableHeight, window.innerHeight * 0.7));

      // Apply the max height to the tags container
      const currentMaxHeight = parseInt(sidebarContent.style.maxHeight || '0', 10);
      if (Math.abs(maxHeight - currentMaxHeight) > 10) {
        sidebarContent.style.maxHeight = `${maxHeight}px`;
        sidebarContent.style.overflowY = 'auto';
      }
    }

    // Debounce function for performance
    function debounce(func: Function, wait: number) {
      let timeout: ReturnType<typeof setTimeout>;
      return function executedFunction(...args: any[]) {
        const later = () => {
          clearTimeout(timeout);
          func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
      };
    }

    function getCategoryAnchorTarget(hash: string) {
      if (!hash || !hash.startsWith('#')) return null;
      const targetId = decodeURIComponent(hash.slice(1));
      return document.getElementById(targetId);
    }

    function getCategoryAnchorOffsetTop(hash: string) {
      const target = getCategoryAnchorTarget(hash) as HTMLElement | null;
      if (!target) return null;

      const header = document.querySelector('#main-header') as HTMLElement | null;
      const headerHeight = header ? header.getBoundingClientRect().height : 0;
      const targetTop = target.getBoundingClientRect().top + window.scrollY;
      return Math.max(0, targetTop - headerHeight - CATEGORY_ANCHOR_EXTRA_OFFSET);
    }

    function easeInOutCubic(t: number) {
      return t < 0.5
        ? 4 * t * t * t
        : 1 - Math.pow(-2 * t + 2, 3) / 2;
    }

    function animateCategoryScrollTo(top: number, duration?: number) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        window.scrollTo({ top, behavior: 'auto' });
        return;
      }

      if (categoryScrollRafId !== null) {
        cancelAnimationFrame(categoryScrollRafId);
        categoryScrollRafId = null;
      }

      const startY = window.scrollY;
      const distance = top - startY;
      if (Math.abs(distance) < 2) {
        window.scrollTo({ top, behavior: 'auto' });
        return;
      }

      const computedDuration = duration ?? Math.min(
        CATEGORY_SCROLL_MAX_DURATION_MS,
        Math.max(CATEGORY_SCROLL_MIN_DURATION_MS, 760 + Math.abs(distance) * 0.46)
      );

      const startTime = performance.now();

      const step = (now: number) => {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / computedDuration, 1);
        const eased = easeInOutCubic(progress);
        window.scrollTo({ top: startY + distance * eased, behavior: 'auto' });

        if (progress < 1) {
          categoryScrollRafId = requestAnimationFrame(step);
        } else {
          categoryScrollRafId = null;
        }
      };

      categoryScrollRafId = requestAnimationFrame(step);
    }

    // Scroll to category title keeping it visible below sticky top header
    function scrollToCategoryAnchor(hash: string, behavior: ScrollBehavior = 'smooth') {
      if (!hash || !hash.startsWith('#')) return;

      const offsetTop = getCategoryAnchorOffsetTop(hash);
      if (offsetTop === null) return;

      if (behavior === 'smooth') {
        animateCategoryScrollTo(offsetTop);
        return;
      }

      window.scrollTo({ top: offsetTop, behavior: 'auto' });
    }

    // Re-apply anchor position after lazy assets/layout shifts
    function stabilizeCategoryAnchor(hash: string) {
      if (categoryStabilizeTimeoutId !== null) {
        window.clearTimeout(categoryStabilizeTimeoutId);
      }

      categoryStabilizeTimeoutId = window.setTimeout(() => {
        const offsetTop = getCategoryAnchorOffsetTop(hash);
        if (offsetTop === null) return;

        const diff = Math.abs(window.scrollY - offsetTop);
        if (diff > 14) {
          animateCategoryScrollTo(offsetTop, 280);
        }
      }, CATEGORY_STABILIZE_DELAY_MS);
    }

    // Bind desktop category links to custom offset scrolling
    function initializeCategoryAnchors() {
      const sidebar = document.querySelector('#tags-sidebar');
      if (!sidebar) return;

      const links = sidebar.querySelectorAll('a[href^="#cat-"]');
      links.forEach((link) => {
        const anchorLink = link as HTMLAnchorElement;
        if (anchorLink.dataset.anchorBound === 'true') return;

        anchorLink.dataset.anchorBound = 'true';
        anchorLink.addEventListener('click', (event) => {
          const href = anchorLink.getAttribute('href');
          if (!href) return;

          const target = getCategoryAnchorTarget(href);
          if (!target) return;

          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
          history.replaceState(null, '', href);
          scrollToCategoryAnchor(href, 'smooth');
          stabilizeCategoryAnchor(href);
        }, { capture: true });
      });

      // If page loads with hash, correct native anchor position with header offset
      if (window.location.hash.startsWith('#cat-')) {
        requestAnimationFrame(() => {
          scrollToCategoryAnchor(window.location.hash, 'auto');
          stabilizeCategoryAnchor(window.location.hash);
        });
      }
    }

    // Global function to initialize tags sidebar
    function initializeTagsSidebar() {
      const sidebarContainer = document.querySelector('#tags-sidebar') as HTMLElement;

      if (!sidebarContainer) return;

      // Calculate initial sidebar height immediately
      updateTagsSidebarHeight();

      // Set up resize observer for height recalculation
      const debouncedUpdateHeight = debounce(() => {
        updateTagsSidebarHeight();
      }, 150);

      window.addEventListener('resize', debouncedUpdateHeight);
      initializeCategoryAnchors();
      initializeCategoryActivePill();
    }

    function initializeCategoryActivePill() {
      const sidebar = document.querySelector('#tags-sidebar') as HTMLElement | null;
      if (!sidebar) return;

      const list = sidebar.querySelector('#categories-menu-list') as HTMLElement | null;
      const pill = sidebar.querySelector('#categories-active-pill') as HTMLElement | null;
      if (!list || !pill) return;
      const pillElement = pill;

      const links = Array.from(sidebar.querySelectorAll('a[href^="#cat-"]')) as HTMLAnchorElement[];
      if (links.length === 0) return;

      const previousCleanup = (window as any).__categoryPillCleanup;
      if (typeof previousCleanup === 'function') {
        previousCleanup();
      }

      let activeLink: HTMLAnchorElement | null = null;
      let rafId: number | null = null;

      function movePillToLink(link: HTMLAnchorElement, instant = false) {
        const listItem = link.closest('li') as HTMLElement | null;
        if (!listItem) return;

        if (instant) {
          pillElement.style.transition = 'none';
        }

        pillElement.style.transform = `translateY(${listItem.offsetTop}px)`;
        pillElement.style.height = `${listItem.offsetHeight}px`;
        pillElement.style.opacity = '1';

        if (instant) {
          requestAnimationFrame(() => {
            pillElement.style.transition = 'transform 640ms cubic-bezier(0.2, 1.2, 0.3, 1), height 640ms cubic-bezier(0.2, 1.2, 0.3, 1), opacity 240ms ease, background 320ms ease, border-color 320ms ease, box-shadow 320ms ease';
          });
        }
      }

      function setActiveLink(link: HTMLAnchorElement, instant = false) {
        if (activeLink === link) return;

        links.forEach((currentLink) => {
          currentLink.classList.remove('category-menu-link-active');
        });

        link.classList.add('category-menu-link-active');
        const pillTone = link.dataset.pillTone;
        if (pillTone) {
          pillElement.classList.remove('pill-tone-1', 'pill-tone-2', 'pill-tone-3', 'pill-tone-4', 'pill-tone-5', 'pill-tone-6');
          pillElement.classList.add(pillTone);
        }
        pillElement.classList.remove('pill-bounce');
        requestAnimationFrame(() => pillElement.classList.add('pill-bounce'));
        activeLink = link;
        movePillToLink(link, instant);
      }

      function getActiveLinkByScroll() {
        const header = document.querySelector('#main-header') as HTMLElement | null;
        const headerHeight = header ? header.getBoundingClientRect().height : 0;
        const threshold = headerHeight + CATEGORY_ANCHOR_EXTRA_OFFSET + 8;

        let currentLink = links[0];

        links.forEach((link) => {
          const hash = link.getAttribute('href');
          if (!hash) return;

          const section = getCategoryAnchorTarget(hash) as HTMLElement | null;
          if (!section) return;

          const top = section.getBoundingClientRect().top;
          if (top - threshold <= 0) {
            currentLink = link;
          }
        });

        return currentLink;
      }

      function refreshActiveFromScroll() {
        if (rafId !== null) return;
        rafId = window.requestAnimationFrame(() => {
          rafId = null;
          const link = getActiveLinkByScroll();
          if (link) setActiveLink(link);
        });
      }

      const linkHandlers: Array<{ link: HTMLAnchorElement; handler: () => void }> = [];
      links.forEach((link) => {
        const clickHandler = () => {
          setActiveLink(link);
        };
        link.addEventListener('click', clickHandler, { capture: true });
        linkHandlers.push({ link, handler: clickHandler });
      });

      window.addEventListener('scroll', refreshActiveFromScroll, { passive: true });
      window.addEventListener('resize', refreshActiveFromScroll);

      setActiveLink(getActiveLinkByScroll(), true);

      (window as any).__categoryPillCleanup = () => {
        window.removeEventListener('scroll', refreshActiveFromScroll);
        window.removeEventListener('resize', refreshActiveFromScroll);
        linkHandlers.forEach(({ link, handler }) => {
          link.removeEventListener('click', handler, { capture: true });
        });
      };
    }

    // Make functions globally available
    (window as any).initializeTagsSidebar = initializeTagsSidebar;
    (window as any).updateTagsSidebarHeight = updateTagsSidebarHeight;

    // Initialize on DOMContentLoaded
    document.addEventListener('DOMContentLoaded', initializeTagsSidebar);

    // Re-initialize after Swup navigation
    if ((window as any).swup?.hooks?.on) {
      (window as any).swup.hooks.on('page:view', initializeTagsSidebar);
    }
  </script>
