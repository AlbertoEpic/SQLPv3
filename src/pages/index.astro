---
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config';
import { generateHomeSEO } from '@/utils/seo';
import { shouldShowPost, sortPostsByDate, processPost } from '@/utils/markdown';
import { getOptimizedFormat, stripObsidianBrackets } from '@/utils/images';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Icon from '@/components/Icon.astro';
import ImageWrapper from '@/components/ImageWrapper.astro';
import logoMiniPlanetas from '@/content/logoMiniPlanetas.png';
import pano360Favicon from '@/content/pano360 favicon-1-180x180.png';

const allPosts = await getCollection('posts');
const isDev = import.meta.env.DEV;
const visiblePosts = allPosts.filter(post => shouldShowPost(post, isDev));
const sortedPosts = sortPostsByDate(visiblePosts);
const processedPosts = await Promise.all(
  sortedPosts.map(async (post) => await processPost(post))
) as any[];

const latestPost = processedPosts[0] || null;

const latestPostImage = (() => {
  if (!latestPost) {
    return null;
  }

  if (!latestPost.data?.image) {
    return {
      src: '/open-graph.png',
      basePath: '',
      preloadHref: '/open-graph.png',
    };
  }

  const rawImage = Array.isArray(latestPost.data.image)
    ? latestPost.data.image[0]
    : latestPost.data.image;

  if (!rawImage || typeof rawImage !== 'string') {
    return {
      src: '/open-graph.png',
      basePath: '',
      preloadHref: '/open-graph.png',
    };
  }

  const cleanImagePath = stripObsidianBrackets(rawImage.trim());
  if (!cleanImagePath) {
    return {
      src: '/open-graph.png',
      basePath: '',
      preloadHref: '/open-graph.png',
    };
  }

  if (cleanImagePath.startsWith('http')) {
    return {
      src: cleanImagePath,
      basePath: '',
      preloadHref: cleanImagePath,
    };
  }

  const isFileBased = cleanImagePath.startsWith('attachments/');

  let normalizedSrc = cleanImagePath;
  if (isFileBased) {
    normalizedSrc = normalizedSrc.replace('attachments/', '');
  } else if (normalizedSrc.startsWith('images/') || normalizedSrc.startsWith('attachments/')) {
    normalizedSrc = normalizedSrc.replace(/^(images|attachments)\//, '');
  }

  const optimizedSrc = getOptimizedFormat(normalizedSrc);
  const basePath = isFileBased ? '/posts/attachments/' : `/posts/${latestPost.id}/`;

  return {
    src: optimizedSrc,
    basePath,
    preloadHref: `${basePath}${optimizedSrc}`,
  };
})();


// --- Panoramicas 360: obtener ultimo producto desde feed XML personalizado ---
let latestPanoLink = null;
let latestPanoTitle = null;
let latestPanoImage = null;
try {
  const res = await fetch('https://pano360.soloquedalopeor.com/wp-content/uploads/woo-feed/custom/xml/feedpano360.xml');
  if (res.ok) {
    const xml = await res.text();
    const products = Array.from(xml.matchAll(/<product>([\s\S]*?)<\/product>/g)).map(m => m[1]);

    if (products.length > 0) {
      const latestProduct = products[0];
      const linkMatch = latestProduct.match(/<link>([\s\S]*?)<\/link>/);
      const titleMatch = latestProduct.match(/<title>([\s\S]*?)<\/title>/);
      const imageMatch = latestProduct.match(/<image_link>([\s\S]*?)<\/image_link>/);

      if (linkMatch && linkMatch[1].includes('/panorama/')) {
        latestPanoLink = linkMatch[1].trim();
        latestPanoTitle = titleMatch ? titleMatch[1].trim() : 'Ver ultima panoramica';
        latestPanoImage = imageMatch ? imageMatch[1].trim() : null;
      }
    }
  }
} catch (e) {
  // Si hay error, dejar latestPanoLink en null
}

let latestMiniPlanetLink = null;
let latestMiniPlanetTitle = null;
let latestMiniPlanetImage = null;

const parseSpanishDiscoveryDate = (rawDate: string) => {
  const monthMap: Record<string, number> = {
    enero: 1,
    febrero: 2,
    marzo: 3,
    abril: 4,
    mayo: 5,
    junio: 6,
    julio: 7,
    agosto: 8,
    septiembre: 9,
    setiembre: 9,
    octubre: 10,
    noviembre: 11,
    diciembre: 12,
  };

  const normalized = rawDate
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/&nbsp;|&#160;/g, ' ')
    .replace(/[.,]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

  const match = normalized.match(/(\d{1,2})(?:\s+de)?\s+([a-z]+)(?:\s+de)?\s+(\d{4})/);
  if (!match) return null;

  const day = Number(match[1]);
  const month = monthMap[match[2]];
  const year = Number(match[3]);
  if (!day || !month || !year) return null;

  return Date.UTC(year, month - 1, day);
};

try {
  const miniBaseUrl = 'https://miniplanetas.soloquedalopeor.com';
  const miniFetchHeaders = {
    'User-Agent': 'Mozilla/5.0 (compatible; SQLP-Astro-Bot/1.0; +https://soloquedalopeor.com)',
    Accept: 'text/html,application/xhtml+xml',
  };

  const catalogRes = await fetch('https://miniplanetas.soloquedalopeor.com/catalogo/', {
    headers: miniFetchHeaders,
  });
  if (catalogRes.ok) {
    const catalogHtml = await catalogRes.text();
    const linkMatches = Array.from(
      catalogHtml.matchAll(/href=["'](https:\/\/miniplanetas\.soloquedalopeor\.com\/planetas\/[^"'#?]+\/?|\/planetas\/[^"'#?]+\/?)["']/gi)
    );

    const planetLinks = Array.from(
      new Set(
        linkMatches
          .map(match => match[1].trim())
          .map(link => (link.startsWith('http') ? link : `${miniBaseUrl}${link}`))
          .filter(link => link.startsWith(`${miniBaseUrl}/planetas/`))
      )
    );

    const planetsWithDate = await Promise.all(planetLinks.map(async (detailUrl) => {

      try {
        const detailRes = await fetch(detailUrl, {
          headers: miniFetchHeaders,
        });
        if (!detailRes.ok) return null;

        const detailHtml = await detailRes.text();
        const detailText = detailHtml
          .replace(/<script[\s\S]*?<\/script>/gi, ' ')
          .replace(/<style[\s\S]*?<\/style>/gi, ' ')
          .replace(/<[^>]+>/g, ' ')
          .replace(/\s+/g, ' ')
          .trim();

        const dateMatch = detailText.match(/Fecha de descubrimiento:\s*([0-9]{1,2}\s*(?:de\s*)?[A-Za-zÁÉÍÓÚÜÑáéíóúüñ]+(?:\s*de)?\s*[0-9]{4})/i);
        if (!dateMatch) return null;

        const timestamp = parseSpanishDiscoveryDate(dateMatch[1]);
        if (!timestamp) return null;

        const titleMatch = detailHtml.match(/<meta\s+property=["']og:title["']\s+content=["']([^"']+)["']/i)
          || detailHtml.match(/<meta\s+content=["']([^"']+)["']\s+property=["']og:title["']/i);
        const imageMatch = detailHtml.match(/<meta\s+property=["']og:image["']\s+content=["']([^"']+)["']/i)
          || detailHtml.match(/<meta\s+content=["']([^"']+)["']\s+property=["']og:image["']/i);

        return {
          link: detailUrl,
          timestamp,
          title: titleMatch ? titleMatch[1].trim() : 'Ver ultimo miniplaneta',
          image: imageMatch ? imageMatch[1].trim() : null,
        };
      } catch {
        return null;
      }
    }));

    const latestPlanet = planetsWithDate
      .filter(Boolean)
      .sort((a, b) => (b?.timestamp || 0) - (a?.timestamp || 0))[0];

    if (latestPlanet) {
      latestMiniPlanetLink = latestPlanet.link;
      latestMiniPlanetTitle = latestPlanet.title;
      latestMiniPlanetImage = latestPlanet.image;
    }
  }
} catch (e) {
  // Si hay error, dejar valores null para fallback visual.
}

const instagramLink = siteConfig.navigation.social.find(
  social => /instagram/i.test(social.title)
)?.url || '#';

const youtubeLink = siteConfig.navigation.social.find(
  social => /youtube/i.test(social.title)
)?.url || '#';

const categoriesMap = new Map<string, { count: number; latestPostId: string; latestPostTitle: string }>();

for (const post of processedPosts) {
  const tags = post?.data?.tags || [];
  for (const tag of tags) {
    if (!categoriesMap.has(tag)) {
      categoriesMap.set(tag, {
        count: 1,
        latestPostId: post.id,
        latestPostTitle: post.data.title,
      });
      continue;
    }

    const current = categoriesMap.get(tag);
    if (!current) continue;

    categoriesMap.set(tag, {
      ...current,
      count: current.count + 1,
    });
  }
}

const categorizedPosts = Array.from(categoriesMap.entries())
  .map(([category, info]) => ({ category, ...info }))
  .sort((a, b) => b.count - a.count || a.category.localeCompare(b.category, 'es'))
  .slice(0, 12);

const seoData = generateHomeSEO(Astro.url.href);
if (siteConfig.homepageTitle) seoData.title = siteConfig.homepageTitle;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: siteConfig.title,
  description: siteConfig.description,
  url: siteConfig.site,
  author: {
    '@type': 'Person',
    name: siteConfig.author
  },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.title,
    url: siteConfig.site
  }
};
---

<BaseLayout seoData={seoData}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    {latestPostImage && (
      <link rel="preload" as="image" href={latestPostImage.preloadHref} fetchpriority="high" />
    )}
  </Fragment>

  <main class="home-cover w-full pb-14">
    <section class="hero-row hero-fullbleed relative overflow-hidden border-b border-primary-200/80 dark:border-primary-700/70">
      <div class="hero-bg absolute inset-0" aria-hidden="true"></div>
      <div class="hero-overlay absolute inset-0" aria-hidden="true"></div>

      <div class="relative px-4 sm:px-6 lg:px-10 py-12 md:py-16 lg:py-20">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.25fr)] items-center">
          <div class="hero-copy max-w-2xl">
            <div class="inline-flex items-center gap-3 rounded-full bg-primary-50/90 dark:bg-primary-900/70 border border-primary-200/90 dark:border-primary-700 px-3 py-2 mb-5">
              <img src="/favicon.png" alt="Logotipo" class="h-8 w-8 rounded-md" loading="eager" fetchpriority="high" />
              {/* <span class="text-sm font-semibold tracking-wide text-primary-800 dark:text-primary-100">{siteConfig.title}</span> */}
            </div>

            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight text-primary-950 dark:text-primary-50">
              Aventuras visuales, rutas y mundos 360 desde SQLP
            </h1>

            <p class="mt-4 text-base sm:text-lg text-primary-700 dark:text-primary-200 max-w-xl">
              La portada se organiza por islas para que entres directo a lo que buscas: blog, panorámicas, miniplanetas y canales sociales.
            </p>

            <div class="mt-6 flex flex-wrap gap-3">
              <a href="/posts" class="hero-btn hero-btn-primary">
                Explorar blog
                <Icon name="arrow-right" class="w-4 h-4" />
              </a>
              <a href="/about" class="hero-btn hero-btn-secondary">
                Sobre mí
              </a>
            </div>
          </div>

          <a href={latestPost ? `/posts/${latestPost.id}` : '/posts'} class="hero-banner group" aria-label="Ir a la última entrada">
            <div class="hero-banner-media">
              {latestPostImage ? (
                <ImageWrapper
                  src={latestPostImage.src}
                  basePath={latestPostImage.basePath}
                  alt={latestPost?.data?.imageAlt || latestPost?.data?.title || 'Ultima entrada'}
                  class="hero-banner-image"
                  width={1200}
                  height={630}
                  loading="eager"
                  fetchpriority="high"
                />
              ) : (
                <div class="hero-banner-fallback" aria-hidden="true"></div>
              )}
            </div>

            <div class="hero-banner-content">
              <p class="text-xs uppercase tracking-[0.18em] text-primary-100/90">Presentación</p>
              <h2 class="text-xl sm:text-2xl font-semibold text-white mt-2 line-clamp-2">
                {latestPost?.data?.title || 'Tu siguiente historia empieza aquí'}
              </h2>
              <p class="text-sm text-primary-100/90 mt-2 line-clamp-2">
                {latestPost?.data?.description || 'Descubre las últimas publicaciones y entra al archivo completo de rutas y experiencias.'}
              </p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="content-row px-4 sm:px-6 lg:px-10 mt-8 md:mt-10">
      <div class="islands-grid-3">
        <article class="island-card">
          <header class="island-head">
            <h3>Ultima entrada del blog</h3>
            <img
              src="/favicon.png"
              alt="SQLP"
              class="w-8 h-8"
              loading="lazy"
              decoding="async"
            />
          </header>
          {latestPost ? (
            <a href={`/posts/${latestPost.id}`} class="island-link">
              {latestPostImage ? (
                <ImageWrapper
                  src={latestPostImage.src}
                  basePath={latestPostImage.basePath}
                  alt={latestPost?.data?.imageAlt || latestPost?.data?.title || 'Ultima entrada del blog'}
                  class="island-post-image rounded-[0.75rem] mb-3"
                  width={800}
                  height={450}
                  loading="lazy"
                />
              ) : (
                <div class="island-post-image island-post-image-fallback" aria-hidden="true"></div>
              )}
              <h4>{latestPost.data.title}</h4>
              <p>{latestPost.data.description || 'Lee la entrada mas reciente del blog.'}</p>
              <span class="island-cta">Leer ahora</span>
            </a>
          ) : (
            <p class="island-empty">Todavia no hay entradas publicadas.</p>
          )}
        </article>

        <article class="island-card">
          <header class="island-head">
            <h3>Panoramicas 360</h3>
            <img
              src={pano360Favicon.src}
              alt="Favicon Pano360"
              class="w-8 h-8"
              loading="lazy"
              decoding="async"
            />
          </header>
          {latestPanoLink ? (
            <a href={latestPanoLink} class="island-link" target="_blank" rel="noopener noreferrer" data-no-swup>
              {latestPanoImage ? (
                <img
                  src={latestPanoImage}
                  alt={latestPanoTitle || 'Ultima panoramica'}
                  class="island-post-image"
                  width="800"
                  height="450"
                  loading="lazy"
                  decoding="async"
                  referrerpolicy="no-referrer"
                />
              ) : (
                <div class="island-post-image island-post-image-fallback" aria-hidden="true"></div>
              )}
              <h4>{latestPanoTitle}</h4>
              <p>Descubre la ultima panoramica publicada en SQLP Pano360.</p>
              <span class="island-cta">Ver panoramica</span>
            </a>
          ) : (
            <div class="island-link island-empty">No se pudo cargar la ultima panoramica.</div>
          )}
        </article>

        <article class="island-card">
          <header class="island-head">
            <h3>Miniplanetas</h3>
            <img
              src={logoMiniPlanetas.src}
              alt="Favicon Miniplanetas"
              class="w-10 h-8"
              loading="lazy"
              decoding="async"
            />
          </header>
          {latestMiniPlanetLink ? (
            <a href={latestMiniPlanetLink} class="island-link" target="_blank" rel="noopener noreferrer" data-no-swup>
              {latestMiniPlanetImage ? (
                <img
                  src={latestMiniPlanetImage}
                  alt={latestMiniPlanetTitle || 'Ultimo miniplaneta'}
                  class="island-post-image"
                  width="800"
                  height="450"
                  loading="lazy"
                  decoding="async"
                  referrerpolicy="no-referrer"
                />
              ) : (
                <div class="island-post-image island-post-image-fallback" aria-hidden="true"></div>
              )}
              <h4>{latestMiniPlanetTitle}</h4>
              <p>Descubre el ultimo miniplaneta publicado en el catalogo.</p>
              <span class="island-cta">Ver miniplaneta</span>
            </a>
          ) : (
            <div class="island-link island-empty">No se pudo cargar el ultimo miniplaneta.</div>
          )}
        </article>
      </div>
    </section>

    <section class="content-row px-4 sm:px-6 lg:px-10 mt-8">
      <article class="island-card island-wide">
        <header class="island-head">
          <h3>Entradas por categorias</h3>
          <Icon name="tag" class="w-4 h-4" />
        </header>

        {categorizedPosts.length > 0 ? (
          <div class="category-grid">
            {categorizedPosts.map((item) => (
              <a href={`/posts/tag/${encodeURIComponent(item.category)}`} class="category-chip">
                <span class="category-name">#{item.category}</span>
                <span class="category-count">{item.count} entradas</span>
                <span class="category-latest">Ultima: {item.latestPostTitle}</span>
              </a>
            ))}
          </div>
        ) : (
          <p class="island-empty">No hay categorias disponibles aun.</p>
        )}
      </article>
    </section>

    <section class="content-row px-4 sm:px-6 lg:px-10 mt-8">
      <div class="social-column">
        <a href={instagramLink} class="social-island" data-no-swup>
          <div class="social-head">
            <Icon name="instagram" class="w-5 h-5" />
            <h3>Instagram</h3>
          </div>
          <p>Fotos, stories y momentos del dia a dia en ruta.</p>
          <span>Ir a Instagram</span>
        </a>

        <a href={youtubeLink} class="social-island" data-no-swup>
          <div class="social-head">
            <Icon name="youtube" class="w-5 h-5" />
            <h3>YouTube</h3>
          </div>
          <p>Videos, recorridos y contenido audiovisual extendido.</p>
          <span>Ir a YouTube</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home-cover {
    background:
      radial-gradient(1200px 380px at 20% -5%, rgb(var(--color-highlight-500) / 0.22), transparent 60%),
      radial-gradient(1000px 420px at 95% 0%, rgb(var(--color-primary-700) / 0.18), transparent 62%),
      rgb(var(--color-primary-50));
  }

  :global(.dark) .home-cover {
    background:
      radial-gradient(1200px 380px at 20% -5%, rgb(var(--color-highlight-500) / 0.2), transparent 60%),
      radial-gradient(1000px 420px at 95% 0%, rgb(var(--color-primary-200) / 0.08), transparent 62%),
      rgb(var(--color-primary-950));
  }

  .hero-row {
    min-height: clamp(26rem, 52vh, 40rem);
  }

  .hero-fullbleed {
    position: relative;
    left: 50%;
    right: 50%;
    width: 100vw;
    max-width: 100vw;
    margin-left: -50vw;
    margin-right: -50vw;
  }

  @supports (width: 100dvw) {
    .hero-fullbleed {
      width: 100dvw;
      max-width: 100dvw;
      margin-left: -50dvw;
      margin-right: -50dvw;
    }
  }

  .hero-bg {
    background-image: linear-gradient(100deg, rgb(var(--color-primary-950) / 0.92), rgb(var(--color-primary-800) / 0.66)), url('/open-graph.png');
    background-size: cover;
    background-position: center;
    filter: saturate(1.15);
  }

  .hero-overlay {
    background: linear-gradient(180deg, rgb(var(--color-primary-900) / 0.08), rgb(var(--color-primary-950) / 0.38));
  }

  .hero-banner {
    display: grid;
    grid-template-rows: minmax(11rem, 1fr);
    border-radius: 1.25rem;
    overflow: hidden;
    border: 1px solid rgb(var(--color-primary-300) / 0.5);
    box-shadow: 0 20px 55px rgb(var(--color-primary-950) / 0.35);
    transform: translateZ(0);
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .hero-banner:hover {
    transform: translateY(-2px);
    box-shadow: 0 26px 60px rgb(var(--color-primary-950) / 0.45);
  }

  .hero-banner-media {
    position: absolute;
    inset: 0;
  }

  .hero-banner-image,
  .hero-banner-fallback {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-banner-fallback {
    background: linear-gradient(130deg, rgb(var(--color-highlight-600) / 0.85), rgb(var(--color-primary-900) / 0.95));
  }

  .hero-banner-content {
    position: relative;
    z-index: 1;
    padding: 1.25rem;
    align-self: end;
    background: linear-gradient(180deg, transparent, rgb(var(--color-primary-950) / 0.88));
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.72rem 1rem;
    border-radius: 0.85rem;
    font-weight: 600;
    transition: all 180ms ease;
  }

  .hero-btn-primary {
    color: rgb(var(--color-primary-50));
    background: rgb(var(--color-highlight-600));
    border: 1px solid rgb(var(--color-highlight-400));
  }

  .hero-btn-primary:hover {
    background: rgb(var(--color-highlight-500));
  }

  .hero-btn-secondary {
    color: rgb(var(--color-primary-100));
    background: rgb(var(--color-primary-900) / 0.42);
    border: 1px solid rgb(var(--color-primary-300) / 0.45);
  }

  .hero-btn-secondary:hover {
    background: rgb(var(--color-primary-900) / 0.58);
  }

  .islands-grid-3 {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  .island-card {
    border: 1px solid rgb(var(--color-primary-200));
    background: rgb(var(--color-primary-50) / 0.8);
    border-radius: 1rem;
    padding: 1rem;
    backdrop-filter: blur(6px);
    box-shadow: 0 14px 35px rgb(var(--color-primary-900) / 0.07);
  }

  :global(.dark) .island-card {
    border-color: rgb(var(--color-primary-700));
    background: rgb(var(--color-primary-900) / 0.62);
  }

  .island-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    color: rgb(var(--color-primary-800));
  }

  :global(.dark) .island-head {
    color: rgb(var(--color-primary-100));
  }

  .island-head h3 {
    font-size: 1rem;
    font-weight: 700;
  }

  .island-link {
    display: block;
  }

  .island-post-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 0.75rem;
    margin-bottom: 0.75rem;
    border: 1px solid rgb(var(--color-primary-200));
  }

  :global(.dark) .island-post-image {
    border-color: rgb(var(--color-primary-700));
  }

  .island-post-image-fallback {
    background: linear-gradient(130deg, rgb(var(--color-highlight-500) / 0.9), rgb(var(--color-primary-800) / 0.9));
  }

  .island-link h4 {
    font-size: 1.05rem;
    font-weight: 600;
    color: rgb(var(--color-primary-900));
  }

  :global(.dark) .island-link h4 {
    color: rgb(var(--color-primary-50));
  }

  .island-link p,
